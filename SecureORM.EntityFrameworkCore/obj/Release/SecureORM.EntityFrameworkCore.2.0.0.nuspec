<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2012/06/nuspec.xsd">
  <metadata>
    <id>SecureORM.EntityFrameworkCore</id>
    <version>2.0.0</version>
    <authors>NoKeyVault</authors>
    <license type="expression">MIT</license>
    <licenseUrl>https://licenses.nuget.org/MIT</licenseUrl>
    <readme>README.md</readme>
    <projectUrl>https://github.com/nokeyvault/SecureORM</projectUrl>
    <description>Entity Framework Core extensions for SecureORM. Transparent order-preserving encoding via attributes and value converters. Native LINQ queries (OpeStartsWith, OpeInRange), key rotation, all .NET numeric types, and column sizing. Query encrypted data without decryption.</description>
    <tags>efcore entity-framework encryption encoding ope order-preserving security database query orm</tags>
    <repository type="git" url="https://github.com/nokeyvault/SecureORM.git" commit="37af5c5ab15162ab829005d702e1f35fc15d938b" />
    <dependencies>
      <group targetFramework="net8.0">
        <dependency id="SecureORM.Core" version="2.0.0" exclude="Build,Analyzers" />
        <dependency id="Microsoft.EntityFrameworkCore" version="8.0.0" exclude="Build,Analyzers" />
        <dependency id="Microsoft.EntityFrameworkCore.Relational" version="8.0.0" exclude="Build,Analyzers" />
        <dependency id="Microsoft.Extensions.DependencyInjection.Abstractions" version="8.0.0" exclude="Build,Analyzers" />
      </group>
    </dependencies>
  </metadata>
